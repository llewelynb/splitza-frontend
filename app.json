{
  "expo": {
    "name": "Splitza",
    "slug": "splitza",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.splitza.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Splitza needs camera access to scan your restaurant receipt.",
        "NSPhotoLibraryUsageDescription": "Splitza needs photo library access to import your receipt."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.splitza.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "Splitza needs photo access to import your receipt."
        }
      ]
    ],
    "scheme": "splitza",
    "web": {
      "bundler": "metro"
    }
  }
}
